# Mission Ready™ environment template
# Copy to a local .env file or configure these values in the hosting dashboard.
# Never commit real credentials.

# Application
APP_ENV=development
APP_BASE_URL=http://localhost:3000
LOG_LEVEL=info

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=

# GoHighLevel
GHL_LOCATION_ID=
GHL_ACCESS_TOKEN=
GHL_API_BASE_URL=https://services.leadconnectorhq.com

# Webhook protection
WEBHOOK_SHARED_SECRET=

# Database (optional during the workshop demo)
DATABASE_URL=

# Demo behavior
DEMO_MODE=true
PROMPT_VERSION=workshop-v1
